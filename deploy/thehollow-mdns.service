[Unit]
Description=Publish thehollow.local mDNS alias for The Hollow menu
Requires=avahi-daemon.service
After=avahi-daemon.service network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/thehollow-mdns.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
