# The Hollow — LAN server: static menu + live ordering API.
# Install at /etc/caddy/Caddyfile (see DEPLOY.md). Point `root` at wherever you
# copied the repo on the NUC.

:80 {
	encode gzip

	# Live ordering API  ->  Node service (server/server.js) on localhost.
	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}

	# Everything else  ->  the static menu files.
	handle {
		root * /srv/the_hollow
		# Editable data files: never cache, so menu edits show up on a refresh.
		@data path /cocktails.js /scale.js
		header @data Cache-Control "no-cache"
		file_server
	}
}
